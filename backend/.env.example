# --- Database ---
# Local dev uses SQLite automatically. In production set the Supabase Postgres URL:
# DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:5432/postgres
DATABASE_URL=sqlite:///./hitech.db

# --- Auth (CHANGE BOTH IN PRODUCTION) ---
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_EMAIL=admin@hitechengineering.com
ADMIN_PASSWORD=changeme123

# --- CORS / frontend ---
CORS_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
REVALIDATE_SECRET=change-me-revalidate

# --- Supabase Storage (optional; local ./uploads used when empty) ---
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=media

# --- Resend email for lead notifications (optional) ---
RESEND_API_KEY=
LEAD_NOTIFY_EMAIL=hi.techengineering1971@gmail.com
LEAD_FROM_EMAIL=leads@yourdomain.com
